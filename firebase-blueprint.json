{
  "entities": {
    "Athlete": {
      "title": "Athlete",
      "description": "Athlete data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "birth_date": { "type": "string" },
        "doc": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "uf": { "type": "string" },
        "jersey_number": { "type": "string" },
        "photo": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string" },
        "guardian_name": { "type": "string" },
        "guardian_doc": { "type": "string" },
        "guardian_phone": { "type": "string" },
        "status": { "type": "string", "enum": ["Ativo", "Inativo"] },
        "modality": { "type": "string" },
        "confirmation": { "type": "string", "enum": ["Pendente", "Confirmado", "Recusado"] }
      },
      "required": ["id", "name", "birth_date", "doc", "status"]
    },
    "Professor": {
      "title": "Professor",
      "description": "Professor data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "birth_date": { "type": "string" },
        "doc": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "uf": { "type": "string" },
        "photo": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "doc"]
    },
    "Event": {
      "title": "Event",
      "description": "Event data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "uf": { "type": "string" },
        "start_date": { "type": "string" },
        "end_date": { "type": "string" },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "responsible_phone": { "type": "string" }
      },
      "required": ["id", "name", "start_date", "end_date"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Attendance data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "athlete_id": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Presente", "Faltou"] },
        "justification": { "type": "string" }
      },
      "required": ["id", "athlete_id", "date", "status"]
    },
    "Anamnesis": {
      "title": "Anamnesis",
      "description": "Anamnesis data model",
      "type": "object",
      "properties": {
        "athlete_id": { "type": "string" },
        "sleep_time": { "type": "string" },
        "wake_up_difficulty": { "type": "string" },
        "fractures": { "type": "string" },
        "medical_treatment": { "type": "string" },
        "controlled_medication": { "type": "string" },
        "other_exercises": { "type": "string" },
        "respiratory_problems": { "type": "string" },
        "cardiac_problems": { "type": "string" },
        "allergies": { "type": "string" },
        "hypertension": { "type": "string" },
        "hypotension": { "type": "string" },
        "epilepsy": { "type": "string" },
        "diabetes": { "type": "string" },
        "food_restriction": { "type": "string" },
        "medication_restriction": { "type": "string" },
        "pathologies": { "type": "string" }
      },
      "required": ["athlete_id"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Settings data model",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "instagram": { "type": "string" },
        "whatsapp": { "type": "string" },
        "schoolCrest": { "type": "string" },
        "president": { "type": "string" },
        "technicalDirector": { "type": "string" },
        "auxiliaryDirector": { "type": "string" },
        "medicalOfficial": { "type": "string" },
        "boardMembers": { "type": "string" },
        "councilors": { "type": "string" },
        "address": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "uf": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "facebook": { "type": "string" },
        "youtube": { "type": "string" },
        "tiktok": { "type": "string" },
        "coaches": { "type": "string" },
        "assistants": { "type": "string" }
      }
    },
    "User": {
      "title": "User",
      "description": "User data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "doc": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "athlete_id": { "type": "string" }
      },
      "required": ["id", "name", "doc", "role"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Sponsor data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["id", "name", "logo"]
    },
    "UniformModel": {
      "title": "UniformModel",
      "description": "Uniform model data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "group": { "type": "string", "enum": ["Viagem", "Jogo", "Torcedor", "Comissão Técnica"] },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "image", "group"]
    },
    "NamedLineup": {
      "title": "NamedLineup",
      "description": "Lineup template data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "athlete_ids": { "type": "array", "items": { "type": "string" } },
        "staff_ids": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "name", "athlete_ids"]
    },
    "Championship": {
      "title": "Championship",
      "description": "Championship data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "dispute_format": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "categories", "dispute_format", "status"]
    },
    "ChampionshipTeam": {
      "title": "ChampionshipTeam",
      "description": "Team registered in a championship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "championship_id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "championship_id", "name", "category", "status"]
    },
    "ChampionshipMatch": {
      "title": "ChampionshipMatch",
      "description": "Match in a championship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "championship_id": { "type": "string" },
        "category": { "type": "string" },
        "team_a_id": { "type": "string" },
        "team_b_id": { "type": "string" },
        "score_a": { "type": "number" },
        "score_b": { "type": "number" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "championship_id", "category", "team_a_id", "team_b_id", "status"]
    },
    "OfficialLetter": {
      "title": "OfficialLetter",
      "description": "Official letter data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "string" },
        "year": { "type": "number" },
        "date": { "type": "string" },
        "recipient_name": { "type": "string" },
        "recipient_role": { "type": "string" },
        "recipient_address": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "closing": { "type": "string" },
        "sender_name": { "type": "string" },
        "sender_role": { "type": "string" },
        "school_info": { "type": "string" },
        "school_cnpj": { "type": "string" },
        "school_cpf": { "type": "string" },
        "departure_location": { "type": "string" },
        "arrival_location": { "type": "string" },
        "departure_time": { "type": "string" },
        "arrival_time": { "type": "string" }
      },
      "required": ["id", "number", "year", "date", "recipient_name", "subject", "body"]
    },
    "Companion": {
      "title": "Companion",
      "description": "Event companion data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "event_id": { "type": "string" },
        "name": { "type": "string" },
        "doc": { "type": "string" },
        "whatsapp": { "type": "string" },
        "presence": { "type": "string", "enum": ["Presente", "Ausente"] },
        "created_at": { "type": "string" }
      },
      "required": ["id", "event_id", "name", "doc"]
    },
    "TrainingActivity": {
      "title": "TrainingActivity",
      "description": "Methodology or training exercise template",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "modality": { "type": "string", "enum": ["Futebol", "Futsal", "Vôlei", "Basquete", "Futebol de Areia", "Outros"] },
        "category": { "type": "string", "enum": ["Fundamento", "Ataque", "Defesa", "Agilidade", "Físico", "Tático", "Goleiro", "Conscientização", "Coordenação Motora", "Aquecimento", "Alongamento", "Outro"] },
        "intensity": { "type": "string", "enum": ["Baixa", "Média", "Alta"] },
        "difficulty": { "type": "string", "enum": ["Iniciante", "Intermediário", "Avançado"] },
        "duration": { "type": "number" },
        "equipment": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "visualData": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "name", "category", "intensity", "modality", "difficulty"]
    },
    "EventMatchScore": {
      "title": "EventMatchScore",
      "description": "Match score within an event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "event_id": { "type": "string" },
        "team_a_name": { "type": "string" },
        "team_b_name": { "type": "string" },
        "score_a": { "type": "number" },
        "score_b": { "type": "number" },
        "scorers_a": { "type": "string" },
        "scorers_b": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "observations": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "event_id", "team_a_name", "team_b_name", "score_a", "score_b"]
    },
    "UniformRequest": {
      "title": "UniformRequest",
      "description": "Uniform request data model",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "athlete_id": { "type": "string" },
        "athlete_name": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string", "enum": ["Conjunto Completo", "Camisa Avulsa"] },
        "uniform_group": { "type": "string", "enum": ["Viagem", "Jogo", "Torcedor", "Comissão Técnica"] },
        "size": { "type": "string", "enum": ["PP", "P", "M", "G", "GG", "XG"] },
        "jersey_number": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendente", "Aprovado", "Entregue", "Recusado"] },
        "sponsor_block_id": { "type": "string" },
        "observations": { "type": "string" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "athlete_id", "category", "size", "jersey_number", "status", "uniform_group"]
    },
    "SponsorBlock": {
      "title": "SponsorBlock",
      "description": "A block of up to 7 sponsors",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sponsors": { "type": "array", "items": { "$ref": "#/entities/Sponsor" } },
        "min_sets": { "type": "number" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      },
      "required": ["id", "name", "sponsors", "min_sets"]
    }
  },
  "firestore": {
    "/athletes/{athleteId}": {
      "schema": "Athlete",
      "description": "Athletes collection"
    },
    "/professors/{professorId}": {
      "schema": "Professor",
      "description": "Professors collection"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Events collection"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/anamnesis/{athleteId}": {
      "schema": "Anamnesis",
      "description": "Anamnesis records indexed by athlete ID"
    },
    "/settings/global_settings": {
      "schema": "Settings",
      "description": "Global application settings"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/sponsors/{sponsorId}": {
      "schema": "Sponsor",
      "description": "Sponsors collection"
    },
    "/uniform_models/{uniformId}": {
      "schema": "UniformModel",
      "description": "Uniform models collection"
    },
    "/named_lineups/{lineupId}": {
      "schema": "NamedLineup",
      "description": "Lineup templates"
    },
    "/championships/{championshipId}": {
      "schema": "Championship",
      "description": "Championships collection"
    },
    "/championship_teams/{teamId}": {
      "schema": "ChampionshipTeam",
      "description": "Teams in championships"
    },
    "/championship_matches/{matchId}": {
      "schema": "ChampionshipMatch",
      "description": "Matches in championships"
    },
    "/official_letters/{letterId}": {
      "schema": "OfficialLetter",
      "description": "Official letters collection"
    },
    "/event_companions/{companionId}": {
      "schema": "Companion",
      "description": "Event companions collection"
    },
    "/training_activities/{activityId}": {
      "schema": "TrainingActivity",
      "description": "Library of training activities and exercises"
    },
    "/event_matches/{matchId}": {
      "schema": "EventMatchScore",
      "description": "Scores for matches within events"
    },
    "/uniform_requests/{requestId}": {
      "schema": "UniformRequest",
      "description": "Requests for uniforms"
    },
    "/sponsor_blocks/{blockId}": {
      "schema": "SponsorBlock",
      "description": "Blocks of sponsors for uniforms"
    }
  }
}
