rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: athletes
    // Fields: id, name, nickname, birth_date, doc, street, number, neighborhood, city, uf, jersey_number, photo, contact, guardian_name, guardian_doc, guardian_phone, status, modality, confirmation
    //
    // Collection: professors
    // Fields: id, name, birth_date, doc, street, number, neighborhood, city, uf, photo, role
    //
    // Collection: events
    // Fields: id, name, street, number, neighborhood, city, uf, start_date, end_date, start_time, end_time
    //
    // Collection: attendance
    // Fields: id, athlete_id, training_id, date, status, justification
    //
    // Collection: trainings
    // Fields: id, date, start_time, end_time, location, modality, category
    //
    // Collection: anamnesis
    // Fields: athlete_id, sleep_time, wake_up_difficulty, fractures, medical_treatment, controlled_medication, other_exercises, respiratory_problems, cardiac_problems, allergies, hypertension, hypotension, epilepsy, diabetes, food_restriction, medication_restriction, pathologies, pathologies_description
    //
    // Collection: settings
    // Fields: primaryColor, secondaryColor, instagram, whatsapp, schoolCrest
    //
    // Collection: users
    // Fields: id, name, doc, role, athlete_id
    //
    // Collection: sponsors
    // Fields: id, name, logo, link
    //
    // Collection: uniform_models
    // Fields: id, name, image, description
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        (
          // Check for primary admin email
          request.auth.token.email == "piruaesporteclube@gmail.com" ||
          // Check for demo user by doc field in their user document (for anonymous)
          (request.auth.token.firebase.sign_in_provider == 'anonymous' && 
           (
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.doc == "05504043689") ||
             // Fallback if user doc doesn't exist yet but we trust the UID if it's the known one 
             // (Not ideal but good for recovery)
             request.auth.uid == "tMltXCnkboSxsDy5ZaPEdAINlQ12"
           )) ||
          // Check if user document exists and has admin role
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isProfessor() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'professor';
    }

    function isStaff() {
      // Direct UID check for known admin who is getting permission errors
      return isAdmin() || isProfessor() || request.auth.uid == "tMltXCnkboSxsDy5ZaPEdAINlQ12";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDataOwner(personId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          ('athlete_id' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.athlete_id == personId) ||
          ('professor_id' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.professor_id == personId)
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidAthlete(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 150 &&
             data.nickname is string && data.nickname.size() > 0 && data.nickname.size() < 100 &&
             data.doc is string && data.doc.size() >= 11 && data.doc.size() <= 20 &&
             data.status in ['Ativo', 'Inativo', 'Suspenso'] &&
             (!('suspension_reason' in data) || data.suspension_reason is string) &&
             data.photo is string && data.photo.size() < 1048576 &&
             data.birth_date is string &&
             data.guardian_name is string &&
             data.guardian_phone is string &&
             (!('modality' in data) || data.modality is string) &&
             (!('school' in data) || data.school is string) &&
             (!('school_shift' in data) || data.school_shift in ['Manhã', 'Tarde', 'Noite', '']);
    }

    function isValidChampionshipTeam(data) {
      return data.name is string && data.name.size() > 0 &&
             data.championship_id is string &&
             data.category is string &&
             data.players is list &&
             data.staff is list &&
             data.status in ['Pendente', 'Aprovado', 'Recusado'];
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 150 &&
             data.doc is string && (data.doc.size() == 0 || (data.doc.size() >= 11 && data.doc.size() <= 20)) &&
             data.role in ['admin', 'student', 'professor'];
    }

    function isValidProfessor(data) {
      return data.name is string && data.name.size() > 0 &&
             data.doc is string && data.doc.size() >= 11 &&
             data.email is string && data.email.size() >= 3 &&
             data.photo is string && data.photo.size() > 0;
    }

    function isValidAnamnesis(data) {
      return data.athlete_id is string && data.athlete_id.size() > 0 &&
             data.sleep_time is string &&
             data.wake_up_difficulty is string &&
             (!('pathologies' in data) || data.pathologies is string) &&
             (!('pathologies_description' in data) || data.pathologies_description is string);
    }

    function isValidPlayerProfile(data) {
      return data.athlete_id is string && data.athlete_id.size() > 0 &&
             (!('nationality' in data) || data.nationality is string) &&
             (!('birth_place' in data) || data.birth_place is string) &&
             (!('primary_position' in data) || data.primary_position is string) &&
             (!('secondary_position' in data) || data.secondary_position is string) &&
             (!('current_club' in data) || data.current_club is string) &&
             (!('contract_duration' in data) || data.contract_duration is string) &&
             (!('category' in data) || data.category is string) &&
             (!('height' in data) || data.height is string) &&
             (!('weight' in data) || data.weight is string) &&
             (!('wingspan' in data) || data.wingspan is string) &&
             (!('imc' in data) || data.imc is string) &&
             (!('dominant_foot' in data) || data.dominant_foot is string) &&
             (!('jersey_number' in data) || data.jersey_number is string) &&
             (!('skills_passing' in data) || data.skills_passing is string) &&
             (!('skills_heading' in data) || data.skills_heading is string) &&
             (!('skills_dribbling' in data) || data.skills_dribbling is string) &&
             (!('skills_speed' in data) || data.skills_speed is string) &&
             (!('skills_tactical' in data) || data.skills_tactical is string) &&
             (!('decision_making' in data) || data.decision_making is string) &&
             (!('rating_passing' in data) || data.rating_passing is number) &&
             (!('rating_finishing' in data) || data.rating_finishing is number) &&
             (!('rating_trapping' in data) || data.rating_trapping is number) &&
             (!('rating_dribbling' in data) || data.rating_dribbling is number) &&
             (!('rating_crossing' in data) || data.rating_crossing is number) &&
             (!('rating_heading' in data) || data.rating_heading is number) &&
             (!('rating_marking' in data) || data.rating_marking is number) &&
             (!('rating_tackling' in data) || data.rating_tackling is number) &&
             (!('rating_vision' in data) || data.rating_vision is number) &&
             (!('rating_positioning' in data) || data.rating_positioning is number) &&
             (!('rating_ball_control' in data) || data.rating_ball_control is number) &&
             (!('rating_speed' in data) || data.rating_speed is number) &&
             (!('rating_acceleration' in data) || data.rating_acceleration is number) &&
             (!('rating_stamina' in data) || data.rating_stamina is number) &&
             (!('rating_strength' in data) || data.rating_strength is number) &&
             (!('rating_agility' in data) || data.rating_agility is number) &&
             (!('rating_jumping' in data) || data.rating_jumping is number) &&
             (!('rating_coordination' in data) || data.rating_coordination is number) &&
             (!('rating_tactical_intelligence' in data) || data.rating_tactical_intelligence is number) &&
             (!('rating_game_reading' in data) || data.rating_game_reading is number) &&
             (!('rating_space_occupation' in data) || data.rating_space_occupation is number) &&
             (!('rating_decision_making' in data) || data.rating_decision_making is number) &&
             (!('rating_offensive_participation' in data) || data.rating_offensive_participation is number) &&
             (!('rating_defensive_participation' in data) || data.rating_defensive_participation is number) &&
             (!('rating_discipline' in data) || data.rating_discipline is number) &&
             (!('rating_leadership' in data) || data.rating_leadership is number) &&
             (!('rating_teamwork' in data) || data.rating_teamwork is number) &&
             (!('rating_commitment' in data) || data.rating_commitment is number) &&
             (!('rating_communication' in data) || data.rating_communication is number) &&
             (!('rating_sportsmanship' in data) || data.rating_sportsmanship is number) &&
             (!('routine_exams' in data) || data.routine_exams is string) &&
             (!('injury_history' in data) || data.injury_history is string) &&
             (!('performance_tests' in data) || data.performance_tests is string);
    }

    function isValidSponsor(data) {
      return data.id is string && data.name is string && data.name.size() > 0 &&
             data.logo is string && data.logo.size() > 0;
    }

    function isValidUniformModel(data) {
      return data.id is string && data.name is string && data.name.size() > 0 &&
             data.image is string && data.image.size() > 0 &&
             data.group in ["Viagem", "Jogo", "Torcedor", "Comissão Técnica"];
    }

    function isValidOfficialLetter(data) {
      return data.number is string && data.number.size() > 0 &&
             data.year is number &&
             data.date is string &&
             data.recipient_name is string && data.recipient_name.size() > 0 &&
             data.subject is string && data.subject.size() > 0 &&
             data.body is string && data.body.size() > 0 &&
             (!('school_info' in data) || data.school_info is string) &&
             (!('school_cnpj' in data) || data.school_cnpj is string) &&
             (!('school_cpf' in data) || data.school_cpf is string) &&
             (!('departure_location' in data) || data.departure_location is string) &&
             (!('arrival_location' in data) || data.arrival_location is string) &&
             (!('departure_time' in data) || data.departure_time is string) &&
             (!('arrival_time' in data) || data.arrival_time is string);
    }

    function isValidCompanion(data) {
      return data.id is string && data.id.size() > 0 &&
             data.event_id is string && data.event_id.size() > 0 &&
             data.name is string && data.name.size() > 2 && data.name.size() < 200 &&
             data.doc is string && data.doc.size() >= 3 && data.doc.size() < 50;
    }

    function isValidTrainingActivity(data) {
      return data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.modality in ["Futebol", "Futsal", "Vôlei", "Basquete", "Futebol de Areia", "Outros"] &&
             data.category in ["Fundamento", "Ataque", "Defesa", "Agilidade", "Físico", "Tático", "Goleiro", "Conscientização", "Coordenação Motora", "Aquecimento", "Alongamento", "Outro"] &&
             data.intensity in ["Baixa", "Média", "Alta"] &&
             data.difficulty in ["Iniciante", "Intermediário", "Avançado"] &&
             (!('duration' in data) || data.duration is number) &&
             (!('description' in data) || data.description is string) &&
             (!('youtubeUrl' in data) || data.youtubeUrl is string) &&
             (!('visualData' in data) || data.visualData is string) &&
             (!('equipment' in data) || data.equipment is string);
    }

    function isValidEventMatch(data) {
      return data.id is string && data.id.size() > 0 &&
             data.event_id is string && data.event_id.size() > 0 &&
             data.team_a_name is string && data.team_a_name.size() > 0 &&
             data.team_b_name is string && data.team_b_name.size() > 0 &&
             data.score_a is number &&
             data.score_b is number &&
             (!('scorers_a' in data) || data.scorers_a is string) &&
             (!('scorers_b' in data) || data.scorers_b is string) &&
             (!('category' in data) || data.category is string);
    }

    function isValidUniformRequest(data) {
      return data.athlete_id is string && data.athlete_id.size() > 0 &&
             data.athlete_name is string && data.athlete_name.size() > 0 &&
             data.category is string &&
             data.type in ["Conjunto Completo", "Camisa Avulsa"] &&
             data.uniform_group in ["Viagem", "Jogo", "Torcedor", "Comissão Técnica"] &&
             data.size in ["1 ANO", "2 ANOS", "4 ANOS", "6 ANOS", "8 ANOS", "10 ANOS", "12 ANOS", "14 ANOS", "16 ANOS", "PP", "P", "M", "G", "GG", "EGG", "XGG", "BLPP", "BLP", "BLM", "BLG", "BLGG", "BLG1", "BLG2", "BLG3", "BLG4"] &&
             data.jersey_number is string && data.jersey_number.size() > 0 &&
             data.status in ["Pendente", "Aprovado", "Entregue", "Recusado"];
    }

    function isValidSponsorBlock(data) {
      return data.name is string && data.name.size() > 0 &&
             data.sponsors is list && data.sponsors.size() >= 0 && data.sponsors.size() <= 7 &&
             data.min_sets is number && data.min_sets >= 40;
    }

    function isValidSchoolReport(data) {
      return data.athlete_id is string && data.athlete_id.size() > 0 &&
             data.report_card_image is string && data.report_card_image.size() > 0 &&
             data.status in ["Pendente", "Visto", "Recusado"] &&
             (!('period' in data) || data.period is string) &&
             (!('year' in data) || data.year is number);
    }

    function isValidAccessLog(data) {
      return data.user_id is string &&
             data.user_name is string &&
             data.role in ['admin', 'student', 'professor'];
    }

    function isValidLoginError(data) {
      return data.doc_attempted is string &&
             data.error_message is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidAthlete(request.resource.data);
      allow update: if isAdmin() || (isDataOwner(athleteId) && isValidAthlete(request.resource.data));
      allow delete: if isAdmin();
    }

    match /professors/{professorId} {
      allow read: if true;
      allow create: if isValidProfessor(request.resource.data);
      allow update: if isAdmin() || (isDataOwner(professorId));
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if hasRequiredFields(['athlete_id', 'date', 'status']) && 
                      request.resource.data.status in ['Presente', 'Faltou', 'Justificado'] &&
                      (!('training_id' in request.resource.data) || request.resource.data.training_id is string);
      allow update: if isStaff() || (
        isAuthenticated() &&
        isDataOwner(resource.data.athlete_id) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['justification', 'updated_at'])
      );
      allow delete: if isStaff();
    }

    match /trainings/{trainingId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /anamnesis/{athleteId} {
      allow read: if isAuthenticated() && (isDataOwner(athleteId) || isAdmin());
      allow create: if isAuthenticated() && isValidAnamnesis(request.resource.data);
      allow update: if isAuthenticated() && (isDataOwner(athleteId) || isAdmin()) && isValidAnamnesis(request.resource.data);
      allow delete: if isAdmin();
    }

    match /player_profiles/{athleteId} {
      allow read: if isAuthenticated() && (isDataOwner(athleteId) || isStaff());
      allow create: if isAuthenticated() && isValidPlayerProfile(request.resource.data);
      allow update: if isAuthenticated() && (isDataOwner(athleteId) || isStaff()) && isValidPlayerProfile(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true; // Publicly readable for theme
      allow write: if isAdmin();
    }

    match /event_lineups/{lineupId} {
      allow read: if true;
      allow create: if isStaff();
      allow delete: if isStaff();
      allow update: if isStaff() || (
        isAuthenticated() &&
        resource.data.type == 'athlete' &&
        isDataOwner(resource.data.person_id) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['confirmation', 'updated_at']) &&
        request.resource.data.confirmation in ['Confirmado', 'Recusado', 'Pendente']
      );
    }

    match /travel_exclusions/{eventId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSponsor(request.resource.data);
      allow delete: if isAdmin();
    }

    match /uniform_models/{uniformId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidUniformModel(request.resource.data);
      allow delete: if isAdmin();
    }

    match /named_lineups/{lineupId} {
      allow read, write: if isStaff();
    }

    match /championships/{championshipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /championship_teams/{teamId} {
      allow read: if true;
      allow create: if isValidChampionshipTeam(request.resource.data); // Allow public registration with validation
      allow update, delete: if isAdmin();
    }

    match /championship_matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /official_letters/{letterId} {
      allow read, write: if isAdmin();
    }

    match /event_companions/{companionId} {
      allow read: if isStaff();
      allow create: if isValidCompanion(request.resource.data) && 
                      exists(/databases/$(database)/documents/events/$(request.resource.data.event_id));
      allow update: if isStaff() && isValidCompanion(request.resource.data);
      allow delete: if isStaff();
    }

    match /training_activities/{activityId} {
      allow read: if isAuthenticated();
      allow create, update: if isStaff() && isValidTrainingActivity(request.resource.data);
      allow delete: if isStaff();
    }

    match /event_matches/{matchId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /uniform_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidUniformRequest(request.resource.data);
      allow update: if isStaff() || (isAuthenticated() && resource.data.athlete_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('athlete_id', '') && resource.data.status == 'Pendente');
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.athlete_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('athlete_id', '') && resource.data.status == 'Pendente');
    }

    match /sponsor_blocks/{blockId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidSponsorBlock(request.resource.data);
      allow delete: if isAdmin();
    }

    match /school_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidSchoolReport(request.resource.data);
      allow update: if isStaff() || (isAuthenticated() && resource.data.athlete_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('athlete_id', '') && resource.data.status == 'Pendente');
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.athlete_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('athlete_id', '') && resource.data.status == 'Pendente');
    }

    match /access_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidAccessLog(request.resource.data);
    }

    match /login_errors/{errorId} {
      allow read: if isAdmin();
      allow create: if isValidLoginError(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
