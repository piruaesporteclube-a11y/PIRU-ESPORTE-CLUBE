rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: athletes
    // Fields: id, name, birth_date, doc, street, number, neighborhood, city, uf, jersey_number, photo, contact, guardian_name, guardian_doc, guardian_phone, status, confirmation
    //
    // Collection: professors
    // Fields: id, name, birth_date, doc, street, number, neighborhood, city, uf, photo
    //
    // Collection: events
    // Fields: id, name, street, number, neighborhood, city, uf, start_date, end_date, start_time, end_time
    //
    // Collection: attendance
    // Fields: id, athlete_id, date, status, justification
    //
    // Collection: anamnesis
    // Fields: athlete_id, sleep_time, wake_up_difficulty, fractures, medical_treatment, controlled_medication, other_exercises, respiratory_problems, cardiac_problems, allergies, hypertension, hypotension, epilepsy, diabetes, food_restriction, medication_restriction, pathologies
    //
    // Collection: settings
    // Fields: primaryColor, secondaryColor, instagram, whatsapp, schoolCrest
    //
    // Collection: users
    // Fields: id, name, doc, role, athlete_id
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an admin
    function isAdmin() {
      return isAuthenticated() &&
        (
          // Check for primary admin email
          request.auth.token.email == "piruaesporteclube@gmail.com" ||
          // Check if user document exists and has admin role
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          // Check for demo user by doc field in their user document (for anonymous)
          (request.auth.token.firebase.sign_in_provider == 'anonymous' && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.doc == "05504043689")
        );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAthleteOwner(athleteId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('athlete_id', '') == athleteId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidAthlete(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.doc is string && data.doc.size() >= 11 &&
             data.status in ['Ativo', 'Inativo'];
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 &&
             data.doc is string &&
             data.role in ['admin', 'student'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if true;
      allow create: if true; // Allow public registration
      allow update, delete: if isAdmin();
    }

    match /professors/{professorId} {
      allow read, write: if true;
    }

    match /events/{eventId} {
      allow read, write: if true;
    }

    match /attendance/{attendanceId} {
      allow read, write: if true;
    }

    match /anamnesis/{athleteId} {
      allow read: if isAuthenticated() && (isAthleteOwner(athleteId) || isAdmin());
      allow create: if true; // Allow public registration
      allow update: if isAuthenticated() && (isAthleteOwner(athleteId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{settingsId} {
      allow read: if true; // Publicly readable for theme
      allow write: if isAdmin();
    }

    match /event_lineups/{lineupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
